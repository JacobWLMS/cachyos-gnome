[Extensions]
window-height=920
window-width=760

[boxes]
first-run=false
view='icon-view'
window-maximized=true
window-position=[20, 20]
window-size=[756, 944]

[control-center]
last-panel='background'
window-state=(980, 640, false)

[desktop/a11y/applications]
screen-reader-enabled=false

[desktop/app-folders]
folder-children=['System', 'Utilities', 'YaST', 'Pardus']

[desktop/app-folders/folders/Pardus]
categories=['X-Pardus-Apps']
name='X-Pardus-Apps.directory'
translate=true

[desktop/app-folders/folders/System]
apps=['nm-connection-editor.desktop', 'btop.desktop', 'btrfs-assistant.desktop', 'org.cachyos.KernelManager.desktop', 'org.gnome.baobab.desktop', 'org.gnome.DiskUtility.desktop', 'org.gnome.Logs.desktop', 'org.freedesktop.MalcontentControl.desktop', 'org.gnome.SystemMonitor.desktop']
name='X-GNOME-Shell-System.directory'
translate=true

[desktop/app-folders/folders/Utilities]
apps=['org.gnome.Decibels.desktop', 'org.gnome.Snapshot.desktop', 'org.gnome.Characters.desktop', 'org.gnome.clocks.desktop', 'org.gnome.Connections.desktop', 'org.gnome.Console.desktop', 'org.gnome.Contacts.desktop', 'org.gnome.SimpleScan.desktop', 'org.gnome.Papers.desktop', 'org.gnome.font-viewer.desktop', 'org.gnome.Yelp.desktop', 'org.gnome.Loupe.desktop', 'org.gnome.Maps.desktop', 'org.gnome.Music.desktop', 'org.gnome.Tour.desktop', 'org.gnome.Showtime.desktop', 'org.gnome.Weather.desktop']
name='X-GNOME-Shell-Utilities.directory'
translate=true

[desktop/app-folders/folders/YaST]
categories=['X-SuSE-YaST']
name='suse-yast.directory'
translate=true

[desktop/background]
color-shading-type='solid'
picture-options='zoom'
picture-uri='file:///usr/share/backgrounds/gnome/blobs-l.svg'
picture-uri-dark='file:///usr/share/backgrounds/gnome/blobs-d.svg'
primary-color='#241f31'
secondary-color='#000000'

[desktop/input-sources]
sources=[('xkb', 'gb')]

[desktop/interface]
accent-color='slate'
color-scheme='prefer-dark'
font-antialiasing='rgba'
icon-theme='Adwaita-Papirus-Apps'

[desktop/notifications]
application-children=['org-gnome-software', 'com-mitchellh-ghostty', 'org-gnome-extensions', 'gnome-about-panel']

[desktop/notifications/application/com-mitchellh-ghostty]
